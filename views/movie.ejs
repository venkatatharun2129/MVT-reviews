<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= movie.title %> (<%= movie.year %>) Review, Rating & Cast | MVT Reviews</title>

<meta name="description" content="<%= movie.title %> review, IMDb rating <%= movie.rating %>/10, cast, story, trailer, screenshots and OTT platform details.">

<link rel="canonical" href="https://www.mvtreviews.free.je/movie/<%= movie.slug || movie._id %>">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
   

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/movie.css">
</head>
<body>

<%- include("partials/header") %>

<div class="movie-container">

    <div class="movie-top">

        <div class="poster-box">
            <img src="<%= movie.poster %>" alt="<%= movie.title %>">
        </div>

        <div class="movie-info">
          <p>Rating: <%= movie.rating %></p>

            <h1><%= movie.title %></h1>

            <div class="ryl">
                <p class="rate">⭐ <%= movie.rating %>/10</p>

                <a class="year" href="/filter?year=<%= movie.year %>">
                    📅 <%= movie.year %>
                </a>

                <a class="language" href="/filter?language=<%= movie.language %>">
                    🗣 <%= movie.language %>
                </a>
            </div>

            <div class="details">
                <p><strong>⏳ Runtime:</strong> <%= movie.runtime %></p>
                <p><strong>🎬 Director:</strong> <%= movie.director %></p>
                <p><strong>🌍 Country:</strong> <%= movie.country %></p>
                <p><strong>🏆 Awards:</strong> <%= movie.awards %></p>
                <p><strong>📆 Released:</strong> <%= movie.released %></p>
            </div>

        </div>

    </div>

    <section>
        <h2>🎭 Categories</h2>

        <% movie.categories?.forEach(category => { %>
            <a class="chip" href="/filter?category=<%= category %>">
                <%= category %>
            </a>
        <% }) %>
    </section>

    <section>
        <h2>👥 Cast</h2>

        <% movie.cast?.forEach(actor => { %>
            <a class="chip cast-chip" href="/actor/<%= actor._id %>">
                <%= actor.name %>
            </a>
        <% }) %>
    </section>

    <section>
        <h2>📝 Review</h2>
        <p><%= movie.review %></p>
    </section>

    <section>
        <h2>📖 Plot</h2>
        <p><%= movie.plot %></p>
    </section>

    <% if(movie.trailer){ %>
    <section>
        <h2>▶ Trailer</h2>

        <iframe
            src="<%= movie.trailer %>"
            allowfullscreen>
        </iframe>
    </section>
    <% } %>

    <% if(movie.watchOn?.length){ %>
    <section>
        <h2>📺 Watch On</h2>

        <div class="platforms">
            <%- include("partials/platform") %>
        </div>
    </section>
    <% } %>

</div>

<%- include("partials/footer") %>

</body>
</html>