<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Movie Details</title>
        <link rel="stylesheet" href="/css/movie.css" />
        <link rel="stylesheet" href="/css/main.css">
    </head>
    <body>
      <%- include('partials/header') %>
        <div class="singleMovie"></div>
        <%- include('partials/footer') %>

        <script>
            const movieId = window.location.pathname.split("/").pop();

            const singleMovie = document.querySelector(".singleMovie");
            //platformLinks
            const platformLinks = {
                YouTube: "https://www.youtube.com",
                Netflix: "https://www.netflix.com",
                "Amazon Prime Video": "https://www.primevideo.com",
                JioHotstar: "https://www.jiohotstar.com",
                Aha: "https://www.aha.video",
                ZEE5: "https://www.zee5.com",
                SonyLIV: "https://www.sonyliv.com",
                JioTv:"https://www.jiotv.com",
                "Sun NXT":"https://www.sunnxt.com"
            };

            async function fetchMovie() {
                try {
                    const response = await fetch(`/api/movies/${movieId}`);
                    const movie = await response.json();
                   
singleMovie.innerHTML = `
<div class="movie-container">

  <!-- TOP SECTION -->
  <div class="top-section">

    <div class="poster">
      <img src="${movie.poster}" alt="${movie.title}" referrerpolicy="no-referrer">
    </div>

    <div class="info">

      <h1 class="title">${movie.title}</h1>

      <div class="meta">
        <span class="rating">⭐ ${movie.rating}/10</span>
        <a href="/filter?year=${movie.year}" class="year">${movie.year}</a>
        <a href="/filter?language=${movie.language}" class="language">${movie.language}</a>
      </div>
<div class="section">
  <h3>Description</h3>

  <p class="review-box">
    ${
      (movie.plot || "No description available.")
        .split(".")
        .filter(sentence => sentence.trim().length > 0)
        .map(sentence => sentence.trim() + ".")
        .join("<br><br>")
    }
  </p>
</div>
      <div class="quick-details">

        <div class="card">⏱️ <b>Runtime</b><br>${movie.runtime || "N/A"}</div>
        <div class="card">📅 <b>Released</b><br>${movie.released || movie.year || "N/A"}</div>
        <div class="card">🎬 <b>Type</b><br>${movie.type || "Movie"}</div>
        <div class="card">🌍 <b>Country</b><br>${movie.country || "N/A"}</div>
        <div class="card">🎥 <b>Director</b><br>${movie.director || "N/A"}</div>
        <div class="card">🏆 <b>Awards</b><br>${movie.awards || "N/A"}</div>

      </div>

    </div>
  </div>

  <!-- CATEGORY -->
  <div class="section">
    <h3>Categories</h3>
    <div class="tag-list">
    ${
  movie.categories?.length
    ? movie.categories.map(cat =>
        `<a class="tag" href="/filter?category=${encodeURIComponent(cat)}">${cat}</a>`
      ).join("")
    : "<p>No categories</p>"
}
    </div>
  </div>

  <!-- CAST -->
  <div class="section">
    <h3>Cast</h3>
    <div class="tag-list">
      ${
        movie.cast?.length
          ? movie.cast.map(actor =>
              `<a class="tag link" href="/actors/${actor._id}/movies">${actor.name}</a>`
            ).join("")
          : "<p>No cast available</p>"
      }
    </div>
  </div>

  <!-- REVIEW -->
  <div class="section">
    <h3>Review</h3>
    <p class="review-box">${movie.review || "No review available."}</p>
  </div>

  <!-- OTT -->
  <div class="section">
    <h3>Watch On</h3>
    <div class="platforms">
      ${
        movie.watchOn?.length
          ? movie.watchOn.map(platform => `
            <a class="platform-btn" href="${platformLinks[platform] || "#"}" target="_blank">
              ${platform}
            </a>
          `).join("")
          : "<p>Not available on OTT platforms</p>"
      }
    </div>
  </div>

  <!-- TRAILER -->
  <div class="section">
    <h3>Trailer</h3>
    ${
      movie.trailer
        ? `<iframe class="trailer"
            src="${movie.trailer}"
            frameborder="0"
            allowfullscreen></iframe>`
        : "<p>Trailer not available</p>"
    }
  </div>

</div>
`;
                    
                        
                } catch (err) {
                    console.log(err);
                }
            }

            fetchMovie();
            

        </script>
    </body>
</html>
