<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Actor Movies</title>
        <link rel="stylesheet" href="/css/main.css">
        <style>

            /* TITLE */
            h1 {
                text-align: center;
                margin: 25px 0;
                font-size: 2rem;
                font-weight: 700;
                letter-spacing: 0.5px;
            }

            /* GRID */
            #movieList {
                display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
                margin: auto;
            }

            /* CARD */
            .movie-card {
                background: linear-gradient(145deg, #1e293b, #0f172a);
                border-radius: 16px;
                overflow: hidden;
                text-decoration: none;
                color: white;
                transition: 0.3s ease;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.35);
                position: relative;
            }

            .movie-card:hover {
                transform: translateY(-6px) scale(1.02);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
            }

            /* IMAGE */
            .movie-card img {
                width: 100%;
                aspect-ratio: 2/3;
                object-fit: cover;
                display: block;
                transition: 0.3s;
            }

            .movie-card:hover img {
                filter: brightness(1.1);
            }

            /* TITLE */
            .movie-card h1 {
                padding: 10px 8px 4px;
                font-size: 14px;
                text-align: center;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            /* RATING */
            .movie-card p {
                text-align: center;
                padding-bottom: 12px;
                font-size: 14px;
                color: #fbbf24;
                font-weight: 600;
            }

            /* LOADING TITLE */
            #actorName {
                text-align: center;
                margin-top: 10px;
                font-size: 1.8rem;
                color: #f8fafc;
            }

            /* RESPONSIVE */
            @media (max-width: 400px) {
                h1 {
                    font-size: 1.5rem;
                }

                #movieList {
                  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
                }
            }
        </style>
    </head>

    <body>
        <%- include('partials/header') %>

        <h1 id="actorName">Loading...</h1>

        <div id="movieList"></div>
        <%- include('partials/footer') %>

        <script>
            const actorId = window.location.pathname.split("/")[2];

            const movieList = document.getElementById("movieList");
            const actorName = document.getElementById("actorName");

            async function fetchActorMovies() {
                const response = await fetch(`/api/actors/${actorId}`);
                const data = await response.json();

                actorName.textContent = data.actor.name;

                movieList.innerHTML = "";

                data.movies.forEach(movie => {
                    movieList.innerHTML += `
      <a href="/movie/${movie._id}" class="movie-card">

        <img
          src="${movie.poster}"
          alt="${movie.title}"
          referrerpolicy="no-referrer"
        >

        <h1>${movie.title}</h1>

        <p>⭐ ${movie.rating?.toFixed(1) || "N/A"}</p>

      </a>
    `;
                });
            }

            fetchActorMovies();
        </script>
    </body>
</html>
