<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Filter Movies - MVT Reviews</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/filter.css">
</head>
<body>

<%- include("partials/header") %>

<div class="container">

    <h1>Filter Movies</h1>

    <form action="/filter" method="GET" class="filter-form">

        <select name="category">
            <option value="">All Categories</option>

            <% filters.categories.forEach(category => { %>
                <option
                    value="<%= category %>"
                    <%= selected.category === category ? "selected" : "" %>>
                    <%= category %>
                </option>
            <% }) %>

        </select>

        <select name="year">
            <option value="">All Years</option>

            <% filters.years.forEach(year => { %>
                <option
                    value="<%= year %>"
                    <%= String(selected.year) === String(year) ? "selected" : "" %>>
                    <%= year %>
                </option>
            <% }) %>

        </select>

        <select name="language">
            <option value="">All Languages</option>

            <% filters.languages.forEach(language => { %>
                <option
                    value="<%= language %>"
                    <%= selected.language === language ? "selected" : "" %>>
                    <%= language %>
                </option>
            <% }) %>

        </select>

        <button type="submit">
            Filter
        </button>

    </form>

<div class="movie-list">
  
<%- include("partials/movieGrid") %>
</div>

<%- include("partials/paging") %>
</div>

<%- include("partials/footer") %>


</body>
</html>