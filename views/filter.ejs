<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
<title>Browse Movies by Category & year & language | MVT Reviews</title>
      <%- include('partials/head')%>

<meta name="description" content="Browse  movies with reviews, ratings, trailers, cast, release dates and OTT information.">
<meta name="keywords" content="movie filter, browse movies, movie categories, movie genres, Telugu movies, Bollywood movies, Hollywood movies, action movies, comedy movies, drama movies, thriller movies, horror movies, romance movies, latest movies, top rated movies, MVT Reviews">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/filter.css">
</head>
<body>

<%- include("partials/header") %>

<div class="container">

    <h1>Filter Movies</h1>

    <form action="/filter" method="GET" class="filter-form">

        <select name="category">
            <option value="">All Categories</option>

            <% filters.categories.forEach(category => { %>
                <option
                    value="<%= category %>"
                    <%= selected.category === category ? "selected" : "" %>>
                    <%= category %>
                </option>
            <% }) %>

        </select>

        <select name="year">
            <option value="">All Years</option>

            <% filters.years.forEach(year => { %>
                <option
                    value="<%= year %>"
                    <%= String(selected.year) === String(year) ? "selected" : "" %>>
                    <%= year %>
                </option>
            <% }) %>

        </select>

        <select name="language">
            <option value="">All Languages</option>

            <% filters.languages.forEach(language => { %>
                <option
                    value="<%= language %>"
                    <%= selected.language === language ? "selected" : "" %>>
                    <%= language %>
                </option>
            <% }) %>

        </select>

        <button type="submit">
            Filter
        </button>

    </form>

<div class="movie-list">
  
<%- include("partials/movieGrid") %>
</div>

<%- include("partials/paging") %>
</div>

<%- include("partials/footer") %>


</body>
</html>